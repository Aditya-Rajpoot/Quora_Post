<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Posts</title>
</head>
<body>
    <h2>Edit your posts</h2>
    <p>Posts id: <%= post.id %> </p>
    <p>Posts username: @<%= post.username %> </p>

    <form method="post" action="/posts/<%=post.id%>?_method=PATCH">
        <textarea rows="10" cols="50" name="content"> <%= post.content %> </textarea>
        <button>Submit</button>
    </form>
</body>
</html>